  "logical_regions": [
    {
      "name": "ngx-region-1a",
      "label": "NGX Region 1A",
      "description": "Primary production region — US East (AWS us-east-1).",
      "provider": "aws",
      "physical_region": "us-east-1",
      "jurisdiction": "US",
      "platform_assigned_only": false,
      "az_maps": [
        {"physical_az": "us-east-1a", "az_index": 1}
      ]
    }
  ],
  "tier_region_members": [
    {"tier": "experimental", "region": "ngx-region-1a", "priority": 1},
    {"tier": "dev",          "region": "ngx-region-1a", "priority": 1},
    {"tier": "tier2",        "region": "ngx-region-1a", "priority": 1},
    {"tier": "tier1",        "region": "ngx-region-1a", "priority": 1}
  ],
  "resource_types": [
    {
      "name": "managed_database",
      "version": 1,
      "label": "Managed Database",
      "latest": true,
      "description": "Managed relational database (PostgreSQL or MySQL). AWS RDS Aurora.",
      "base_config_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "additionalProperties": false,
        "required": ["engine", "size"],
        "properties": {
          "engine":     {"type": "string", "enum": ["postgres", "mysql"]},
          "size":       {"type": "string", "enum": ["small", "medium", "large", "xlarge"]},
          "storage_gb": {"type": "integer", "minimum": 20, "maximum": 16000, "default": 100}
        }
      },
      "terraform_variable_map": {
        "engine": "db_engine",
        "size": "db_size",
        "storage_gb": "db_storage_gb"
      }
    },
    {
      "name": "managed_compute",
      "version": 1,
      "label": "Managed Compute",
      "latest": true,
      "description": "Managed container compute cluster. AWS ECS/EKS.",
      "base_config_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "additionalProperties": false,
        "required": ["size"],
        "properties": {
          "size":         {"type": "string", "enum": ["small", "medium", "large"]},
          "min_nodes":    {"type": "integer", "minimum": 1, "default": 2},
          "max_nodes":    {"type": "integer", "minimum": 1, "maximum": 50, "default": 10},
          "database_url": {"type": "string"}
        }
      },
      "terraform_variable_map": {
        "size": "compute_size",
        "min_nodes": "min_nodes",
        "max_nodes": "max_nodes",
        "database_url": "database_url"
      }
    }
  ]
}
