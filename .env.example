# Example local .env for Forge.
# Copy to `.env` (gitignored) and edit as needed for local development.
# All Forge settings are prefixed with FORGE_; baseline values live in
# src/forge/config.py DEFAULT_SETTINGS and only need to be set here when
# overriding the default.

# Application identity
FORGE_APP_NAME=Forge
FORGE_ENVIRONMENT=dev
FORGE_LOG_LEVEL=INFO

# Network binding (used by `python -m forge` to start uvicorn)
FORGE_HOST=0.0.0.0
FORGE_PORT=8000

# Set to true for hot-reload during local dev
FORGE_RELOAD=false
