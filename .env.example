# Example local .env for Forge.
# Copy to `.env` (gitignored) and edit as needed for local development.
# All Forge settings are prefixed with FORGE_; baseline values live in
# src/forge/config.py DEFAULT_SETTINGS and only need to be set here when
# overriding the default.

# Application identity
FORGE_APP_NAME=Forge
FORGE_ENVIRONMENT=dev
FORGE_LOG__LEVEL=DEBUG

# Network binding (used by `python -m forge` to start uvicorn)
# Default in code is 127.0.0.1 (loopback). Uncomment FORGE_HOST=0.0.0.0
# to bind publicly. docker-compose sets FORGE_HOST=0.0.0.0 automatically
# for the api container, so no need to set it here for the compose stack.
# FORGE_HOST=0.0.0.0
FORGE_PORT=8000

# Set to true for hot-reload during local dev
FORGE_RELOAD=false

# Database — maps to settings.database.* via FORGE_DATABASE__ prefix
# For local dev these match the docker-compose postgres service defaults.
# FORGE_DATABASE__PASSWORD is required and intentionally omitted here — set it in .env (gitignored).
FORGE_DATABASE__HOST=localhost
FORGE_DATABASE__PORT=5432
FORGE_DATABASE__NAME=forge
FORGE_DATABASE__USER=forge
FORGE_DATABASE__SSL_MODE=disable

# Celery broker — maps to settings.celery.* via FORGE_CELERY__ prefix.
# Local dev points at the docker-compose redis service. Production points at
# an AWS Elasticache for Redis primary endpoint, set in the ECS task definition
# (e.g. rediss://<cluster-endpoint>:6379/0 for TLS).
# The result backend is auto-derived from FORGE_DATABASE__* (we reuse Aurora
# for task results — Celery creates celery_taskmeta in the public schema).
FORGE_CELERY__BROKER_URL=redis://localhost:6379/0

# AWS provider settings — maps to settings.aws.* via FORGE_AWS__ prefix.
# Local dev typically leaves these unset / empty: with an empty role-arn map
# the worker injects managed_resources_role_arn="" into each package's tfvars,
# the package's gated `assume_role` block collapses, and terraform uses the
# developer's ambient AWS credentials (e.g. AWS_PROFILE, instance metadata).
# Cloud envs set these via the ECS task definition.
# FORGE_AWS__REGION=us-east-1
# FORGE_AWS__PROFILE=
# FORGE_AWS__MANAGED_RESOURCES_ROLE_ARNS={"database":"arn:aws:iam::123456789012:role/forge-managed-database-role"}
