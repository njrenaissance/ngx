# Copy to terraform.tfvars (gitignored) and edit for local use.
# In CI, these are passed via TF_VAR_<name> environment variables instead.

aws_region  = "us-east-1"
environment = "dev"

# app_image has no default — set it before applying. CI resolves this to the
# current `:latest` tag in ECR; for a manual local apply, point at a specific
# version tag you've pushed.
#   Latest from ECR (use what CI uses):
#     app_image = "328926346833.dkr.ecr.us-east-1.amazonaws.com/forge-dev:latest"
#   Pinned version:
#     app_image = "328926346833.dkr.ecr.us-east-1.amazonaws.com/forge-dev:0.1.0"
app_image = "328926346833.dkr.ecr.us-east-1.amazonaws.com/forge-dev:latest"

# Managed-resources backend (issue #51 / E.3). Read from `terraform output`
# in infrastructure/bootstrap/ after the bootstrap apply, or query directly:
#   terraform -chdir=infrastructure/bootstrap output managed_resources_bucket_name
#   terraform -chdir=infrastructure/bootstrap output managed_resources_bucket_region
#   terraform -chdir=infrastructure/bootstrap output managed_resources_kms_key_arn
managed_resources_bucket      = "forge-managed-resources-328926346833"
managed_resources_region      = "us-east-1"
managed_resources_kms_key_arn = "arn:aws:kms:us-east-1:328926346833:key/REPLACE-WITH-KMS-KEY-UUID"

# Per-package managed-resources IAM identities (issue #86). Read from
# `terraform output` in infrastructure/bootstrap/ after the bootstrap apply:
#   terraform -chdir=infrastructure/bootstrap output managed_database_role_arn
managed_database_role_arn = "arn:aws:iam::328926346833:role/forge-managed-database-role"
